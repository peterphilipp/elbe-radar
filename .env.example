# aisstream.io API Key (kostenlos: https://aisstream.io)
AIS_API_KEY=your_aisstream_key_here

# Telegram Bot Token (von @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Chat-ID (eigene ID: @userinfobot fragen)
TELEGRAM_CHAT_ID=your_chat_id

# Domain für Traefik (deine DynDNS-Domain)
DOMAIN=elbe.deinedomain.de

# Port des Backends (intern)
PORT=3000

# Mindestlänge für Telegram-Alerts (in Meter)
ALERT_MIN_LENGTH=200

# Optional: API-Schlüssel zum Schutz der Alert-Verwaltung (leer = kein Schutz)
API_SECRET=

# Einladungscode für neue Registrierungen (leer = jeder kann sich registrieren)
REGISTRATION_CODE=

# App-URL (für Passwort-Reset-Links in E-Mails)
APP_URL=https://deine-domain.de

# SMTP für Passwort-Reset-E-Mails (leer = kein E-Mail-Versand, nur Log-Ausgabe)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Elbe Radar <noreply@example.com>
